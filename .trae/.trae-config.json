{
  "trae_ai_assistant": {
    "version": "4.0",
    "mode": "principle_driven",
    "development_modes": {
      "ide_mode": {
        "name": "IDE模式",
        "description": "保留原有流程，控制感更强",
        "features": [
          "智能体协作",
          "工作流管理",
          "代码生成",
          "实时预览"
        ]
      },
      "solo_mode": {
        "name": "SOLO模式",
        "description": "让AI主导任务，自动推进开发任务",
        "features": [
          "自然语言输入",
          "自动任务分解",
          "自主代码生成",
          "智能决策执行"
        ],
        "agent": "SOLO Coder",
        "capabilities": [
          "需求理解",
          "架构设计",
          "代码实现",
          "测试验证"
        ]
      }
    },
    "mcp_support": {
      "enabled": true,
      "description": "模型上下文协议支持，连接外部工具和数据源",
      "config_file": ".trae/mcp-config.json",
      "available_servers": [
        "filesystem",
        "brave-search",
        "postgres",
        "sqlite",
        "supabase",
        "figma",
        "github",
        "gitlab"
      ],
      "default_servers": [
        "filesystem",
        "brave-search"
      ]
    },
    "context_management": {
      "enabled": true,
      "description": "上下文管理功能，支持#Web和#Doc引用",
      "features": {
        "web_context": {
          "name": "#Web",
          "description": "引用网络资源作为上下文",
          "usage": "#Web URL或搜索查询"
        },
        "doc_context": {
          "name": "#Doc",
          "description": "引用文档集作为上下文",
          "usage": "#Doc 文档路径或集合名称"
        }
      },
      "best_practices": [
        "先引用文档集，再提出具体需求",
        "使用#Web获取最新技术信息",
        "使用#Doc引用项目文档",
        "避免需求偏差"
      ]
    },
    "agent_marketplace": {
      "enabled": true,
      "description": "智能体市场，支持智能体分享和组合",
      "market_url": "https://marketplace.trae.ai",
      "shareable": true,
      "composable": true,
      "categories": [
        "frontend",
        "backend",
        "management",
        "testing",
        "devops",
        "design",
        "documentation"
      ]
    },
    "core_principles": {
      "P-001": "需求澄清原则",
      "P-002": "技术选型对比原则",
      "P-003": "文档驱动开发原则",
      "P-004": "渐进式实施原则",
      "P-005": "自动化文档生成原则",
      "P-006": "高效沟通协作原则",
      "P-007": "时间信息原则",
      "P-008": "结构化沟通原则",
      "P-009": "测试优先原则",
      "P-010": "安全优先原则",
      "P-011": "性能优化原则",
      "P-012": "可持续维护原则",
      "P-013": "AI共生宪法原则",
      "P-014": "智能感知原则",
      "P-015": "自适应学习原则"
    },
    "cursor_constitution": {
      "human_intent_sovereignty": {
        "principle": "人类意图主权",
        "description": "人类决策始终优先于AI建议，AI提供选项，人类做出最终选择",
        "requirements": [
          "人类决策优先于AI建议",
          "AI提供选项，人类做出最终选择",
          "所有AI操作都需要人类确认"
        ]
      },
      "signal_transparency": {
        "principle": "信号透明性",
        "description": "AI必须解释推理过程和数据来源，所有输出都应可追溯和可验证",
        "requirements": [
          "AI必须解释推理过程和数据来源",
          "所有输出都应可追溯和可验证",
          "明确标注信息来源归属"
        ]
      },
      "safe_collaboration": {
        "principle": "安全协作",
        "description": "不自动执行破坏性操作，所有系统变更都需要明确批准",
        "requirements": [
          "不自动执行破坏性操作",
          "所有系统变更都需要明确批准",
          "对所有建议进行风险评估"
        ]
      }
    },
    "interaction_modes": {
      "direct_call": "@智能体名 需求描述",
      "project_mode": "#项目类型 需求描述",
      "principle_mode": "!原则 需求描述"
    },
    "response_format": {
      "structured": true,
      "include_code": true,
      "include_plan": true,
      "include_next_steps": true,
      "mandatory_sections": [
        "需求重述",
        "方案对比",
        "实施计划",
        "文档清单"
      ]
    },
    "workflows": {
      "project_startup": {
        "name": "原则驱动的项目启动",
        "description": "基于P-001~P-012的完整开发流程",
        "prerequisites": [
          "principles.md"
        ],
        "steps": [
          {
            "step": 1,
            "agent": "@产品经理",
            "action": "需求澄清",
            "principle": "P-001",
            "output": "docs/requirements.md"
          },
          {
            "step": 2,
            "agent": "@系统架构师",
            "action": "技术选型对比",
            "principle": "P-002",
            "output": "docs/tech-choice.md"
          },
          {
            "step": 3,
            "agent": "@项目经理",
            "action": "渐进式计划制定",
            "principle": "P-004",
            "output": "docs/roadmap.md"
          },
          {
            "step": 4,
            "agent": "@技术文档工程师",
            "action": "文档框架建立",
            "principle": "P-003",
            "output": "docs/structure.md",
            "action_details": "自动生成API文档和用户手册，确保docs目录下包含所有必要文档"
          },
          {
            "step": 5,
            "agent": "@测试工程师",
            "action": "测试用例设计",
            "principle": "P-009",
            "output": "tests/test-cases.md"
          },
          {
            "step": 6,
            "agent": "@DevOps工程师",
            "action": "安全配置检查",
            "principle": "P-010",
            "output": "docs/security-config.md"
          },
          {
            "step": 7,
            "agent": "开发工程师",
            "action": "MVP开发",
            "principle": "P-004",
            "output": "代码+测试"
          },
          {
            "step": 8,
            "agent": "@系统架构师",
            "action": "性能优化分析",
            "principle": "P-011",
            "output": "docs/performance-report.md"
          },
          {
            "step": 9,
            "agent": "@技术文档工程师",
            "action": "维护文档生成",
            "principle": "P-012",
            "output": "docs/maintenance-guide.md"
          }
        ]
      },
      "tech_selection": {
        "name": "技术选型流程",
        "description": "基于P-002的标准化技术选型",
        "template": {
          "scheme_a": {
            "name": "",
            "pros": [],
            "cons": [],
            "score": 0
          },
          "scheme_b": {
            "name": "",
            "pros": [],
            "cons": [],
            "score": 0
          },
          "scheme_c": {
            "name": "",
            "pros": [],
            "cons": [],
            "score": 0
          }
        }
      },
      "structured_communication": {
        "name": "结构化沟通流程",
        "description": "基于P-008的标准化沟通模式",
        "template": {
          "understanding": "我理解你的需求是...",
          "thinking": "我的思考过程是...",
          "solution": "解决方案有A/B两种...",
          "execution": "直接执行/需要你决策"
        }
      }
