{
  "trae_ai_assistant": {
    "version": "2.0",
    "mode": "in_dialog",
    "interaction_modes": {
      "direct_call": "@智能体名 需求描述",
      "project_mode": "#项目类型 需求描述"
    },
    "response_format": {
      "structured": true,
      "include_code": true,
      "include_plan": true,
      "include_next_steps": true
    },
    "workflows": {
      "project_startup": {
        "name": "项目启动",
        "description": "从需求到代码的完整流程",
        "steps": [
          {
            "step": 1,
            "agent": "@产品经理",
            "action": "需求分析",
            "output": "功能清单"
          },
          {
            "step": 2,
            "agent": "@系统架构师",
            "action": "技术选型",
            "output": "技术方案"
          },
          {
            "step": 3,
            "agent": "@项目经理",
            "action": "任务分解",
            "output": "开发计划"
          },
          {
            "step": 4,
            "agent": "开发工程师",
            "action": "代码实现",
            "output": "项目代码"
          }
        ]
      }
    }
  }
}