{
  "team_name": "超级个体开发团队",
  "version": "2.0.0",
  "description": "专为超级个体设计的自然语言开发团队，支持多技术栈选择，严格Review流程",
  "roles": [
    {
      "name": "产品经理",
      "role": "product-manager",
      "description": "负责小型/工具型产品的需求分析、竞品分析、经济可行性评估"
    },
    {
      "name": "UI-X设计师",
      "role": "ui-x-designer",
      "description": "统一负责所有平台的界面设计和交互设计"
    },
    {
      "name": "系统架构师",
      "role": "system-architect",
      "description": "负责技术选型（开源社区前3）和架构设计"
    },
    {
      "name": "Vue工程师",
      "role": "vue-engineer",
      "description": "专精Vue.js前端开发（第1优先级）"
    },
    {
      "name": "React工程师",
      "role": "react-engineer",
      "description": "专精React前端开发（第2优先级）"
    },
    {
      "name": "Angular工程师",
      "role": "angular-engineer",
      "description": "专精Angular前端开发（第3优先级）"
    },
    {
      "name": "Python AI工程师",
      "role": "python-ai-engineer",
      "description": "专精Python AI开发，负责CV算法、神经网络模型、PyTorch框架应用及AI工具开发"
    },
    {
      "name": "C++ AI部署工程师",
      "role": "cpp-ai-deployment-engineer",
      "description": "专精C++ AI模型部署，负责跨平台推理优化、CMake构建、TensorRT/ONNX Runtime/ncnn集成及高性能部署"
    },
    {
      "name": "Flutter工程师",
      "role": "flutter-engineer",
      "description": "专精Flutter跨平台移动应用开发，支持iOS/Android/Web三端统一"
    },
    {
      "name": "Go工程师",
      "role": "go-engineer",
      "description": "专精Go语言高性能后端开发，支持微服务架构和云原生部署"
    },
    {
      "name": "Rust工程师",
      "role": "rust-engineer",
      "description": "专精Rust系统级编程，支持高性能Web服务和WebAssembly开发"
    },
    {
      "name": "FastAPI工程师",
      "role": "fastapi-engineer",
      "description": "专精FastAPI后端开发"
    },
    {
      "name": "Node.js工程师",
      "role": "nodejs-engineer",
      "description": "专精Node.js后端开发"
    },
    {
      "name": "测试工程师",
      "role": "test-engineer",
      "description": "负责跨技术栈的测试策略和质量保证"
    },
    {
      "name": "运维工程师",
      "role": "devops-engineer",
      "description": "负责跨技术栈的部署和运维"
    },
    {
      "name": "技术文档工程师",
      "role": "technical-writer",
      "description": "统一整理所有阶段文档，Markdown格式输出"
    }
  ],
  "workflow_stages": [
    {
      "stage": "需求分析",
      "role": "product-manager",
      "outputs": [
        "市场分析报告",
        "用户故事",
        "MVP计划"
      ],
      "review_required": true
    },
    {
      "stage": "界面设计",
      "role": "ui-x-designer",
      "outputs": [
        "HTML原型",
        "设计系统",
        "样式指南"
      ],
      "review_required": true
    },
    {
      "stage": "架构设计",
      "role": "system-architect",
      "outputs": [
        "技术选型报告",
        "系统架构",
        "API规范"
      ],
      "review_required": true
    },
    {
      "stage": "前端开发",
      "role": "vue-engineer",
      "outputs": [
        "前端代码",
        "组件库",
        "构建配置"
      ],
      "review_required": true
    },
    {
      "stage": "后端开发",
      "role": "fastapi-engineer",
      "outputs": [
        "后端代码",
        "API实现",
        "数据库设计"
      ],
      "review_required": true
    },
    {
      "stage": "测试验证",
      "role": "test-engineer",
      "outputs": [
        "测试计划",
        "测试用例",
        "测试报告"
      ],
      "review_required": true
    },
    {
      "stage": "部署运维",
      "role": "devops-engineer",
      "outputs": [
        "Docker配置",
        "CI/CD配置",
        "部署指南"
      ],
      "review_required": true
    },
    {
      "stage": "文档维护",
      "role": "technical-writer",
      "outputs": [
        "完整技术文档",
        "用户手册",
        "API文档"
      ],
      "review_required": true
    }
  ],
  "tech_stack_priority": {
    "frontend": ["Vue", "React", "Angular", "Flutter"],
    "backend": ["FastAPI", "Node.js", "Go", "Rust"]
  },
  "documentation": {
    "format": "markdown",
    "naming_convention": "{stage}-{description}.md",
    "required_sections": ["概述", "实现细节", "测试要点", "Review记录"]
  },
  "migration": {
    "supported_formats": ["json", "yaml", "md"],
    "export_paths": [
      ".trae/agents",
      ".trae/rules",
      ".trae/templates",
      ".trae/config"
    ],
    "dependencies": {
      "required": ["Node.js >= 16", "Git"],
      "optional": ["Docker", "Kubectl"]
    }
  }
}