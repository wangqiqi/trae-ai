{
  "name": "MVP Web应用模板",
  "version": "1.0.0",
  "description": "Vue3 + FastAPI + SQLite的MVP极速开发模板，1-2周交付完整产品，内置编码问题自动修复",
  "type": "mvp_web_app",
  "timeline": {
    "total_duration": "1-2周",
    "phases": [
      {
        "name": "项目初始化",
        "duration": "1小时",
        "description": "使用MVP模板快速创建项目结构"
      },
      {
        "name": "基础功能开发",
        "duration": "3-5天",
        "description": "完成核心CRUD功能"
      },
      {
        "name": "编码问题修复",
        "duration": "自动",
        "description": "自动处理中文乱码、端口冲突等问题"
      },
      {
        "name": "测试优化",
        "duration": "2-3天",
        "description": "功能测试和性能优化"
      },
      {
        "name": "部署上线",
        "duration": "1天",
        "description": "生产环境部署"
      }
    ]
  },
  "technology_stack": {
    "frontend": {
      "framework": "Vue3",
      "language": "TypeScript",
      "ui_library": "Element Plus",
      "state_management": "Pinia",
      "router": "Vue Router 4"
    },
    "backend": {
      "framework": "FastAPI",
      "language": "Python",
      "database": "SQLite",
      "orm": "SQLAlchemy",
      "authentication": "JWT"
    },
    "deployment": {
      "development": "localhost:8003",
      "frontend": "localhost:3001",
      "production": "Docker + Nginx"
    }
  },
  "features": [
    {
      "name": "用户管理",
      "description": "注册、登录、用户信息管理",
      "priority": "P0"
    },
    {
      "name": "CRUD操作",
      "description": "创建、读取、更新、删除功能",
      "priority": "P0"
    },
    {
      "name": "响应式设计",
      "description": "支持PC和移动端",
      "priority": "P0"
    },
    {
      "name": "数据验证",
      "description": "前后端数据验证",
      "priority": "P1"
    },
    {
      "name": "错误处理",
      "description": "友好的错误提示",
      "priority": "P1"
    }
  ],
  "auto_fixes": [
    {
      "issue": "中文乱码",
      "solution": "Python UTF-8强制设置 + 数据库UTF-8配置 + 响应头charset设置"
    },
    {
      "issue": "端口冲突",
      "solution": "自动检测端口占用 + 动态端口分配 + 进程清理"
    },
    {
      "issue": "依赖冲突",
      "solution": "虚拟环境隔离 + 版本锁定 + 自动依赖解析"
    }
  ],
  "project_structure": {
    "frontend": {
      "src/": [
        "components/",
        "views/",
        "stores/",
        "api/",
        "router/",
        "utils/"
      ],
      "public/": [
        "index.html",
        "favicon.ico"
      ],
      "package.json": "Vue3 + Vite + TypeScript 配置"
    },
    "backend": {
      "app/": [
        "models/",
        "routers/",
        "schemas/",
        "crud/",
        "core/"
      ],
      "requirements.txt": "FastAPI + SQLAlchemy 依赖",
      "main.py": "FastAPI 主入口"
    }
  },
  "commands": {
    "init": "复制模板并初始化项目",
    "dev": "启动开发环境",
    "build": "构建生产版本",
    "deploy": "部署到生产环境"
  },
  "roles": {
    "required": [
      "vue-engineer",
      "fastapi-engineer"
    ],
    "optional": [
      "project-manager",
      "ui-x-designer"
    ]
  },
  "milestones": [
    {
      "name": "项目启动",
      "deliverable": "完整的项目结构",
      "criteria": "前后端框架搭建完成"
    },
    {
      "name": "功能完成",
      "deliverable": "可运行的CRUD应用",
      "criteria": "所有核心功能正常"
    },
    {
      "name": "编码修复",
      "deliverable": "无编码问题的应用",
      "criteria": "中文显示正常，端口无冲突"
    },
    {
      "name": "产品交付",
      "deliverable": "生产就绪的MVP产品",
      "criteria": "部署成功，性能达标"
    }
  ]
}