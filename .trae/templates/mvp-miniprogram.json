{
  "name": "MVP小程序模板",
  "version": "1.0.0",
  "description": "uni-app + FastAPI + SQLite的MVP小程序开发模板，3-7天交付完整产品，支持微信/支付宝/百度多端发布",
  "type": "mvp_miniprogram",
  "timeline": {
    "total_duration": "3-7天",
    "phases": [
      {
        "name": "项目初始化",
        "duration": "2小时",
        "description": "使用MVP模板创建uni-app项目"
      },
      {
        "name": "小程序功能开发",
        "duration": "2-4天",
        "description": "完成核心小程序功能"
      },
      {
        "name": "多端适配",
        "duration": "1天",
        "description": "适配微信、支付宝、百度小程序"
      },
      {
        "name": "后端API开发",
        "duration": "1-2天",
        "description": "FastAPI后端接口开发"
      },
      {
        "name": "测试发布",
        "duration": "1天",
        "description": "各平台测试和发布"
      }
    ]
  },
  "technology_stack": {
    "frontend": {
      "framework": "uni-app",
      "language": "Vue.js",
      "target_platforms": ["微信小程序", "支付宝小程序", "百度小程序", "QQ小程序"],
      "ui_library": "uView UI",
      "state_management": "Vuex"
    },
    "backend": {
      "framework": "FastAPI",
      "language": "Python",
      "database": "SQLite",
      "orm": "SQLAlchemy",
      "authentication": "JWT"
    },
    "deployment": {
      "development": "localhost:8003",
      "production": "各小程序平台"
    }
  },
  "features": [
    {
      "name": "用户授权登录",
      "description": "微信/支付宝授权登录",
      "priority": "P0"
    },
    {
      "name": "商品展示",
      "description": "商品列表和详情页",
      "priority": "P0"
    },
    {
      "name": "购物车",
      "description": "添加商品到购物车",
      "priority": "P0"
    },
    {
      "name": "订单管理",
      "description": "创建和管理订单",
      "priority": "P0"
    },
    {
      "name": "支付集成",
      "description": "微信支付和支付宝支付",
      "priority": "P1"
    },
    {
      "name": "分享功能",
      "description": "小程序内分享",
      "priority": "P1"
    }
  ],
  "platform_configs": {
    "wechat": {
      "appid": "请填写微信小程序AppID",
      "setting": {
        "urlCheck": false,
        "es6": true,
        "enhance": true
      }
    },
    "alipay": {
      "appid": "请填写支付宝小程序AppID",
      "setting": {
        "enableAppxNg": true
      }
    },
    "baidu": {
      "appid": "请填写百度小程序AppID",
      "setting": {
        "urlCheck": false
      }
    }
  },
  "auto_fixes": [
    {
      "issue": "中文乱码",
      "solution": "Python UTF-8设置 + 数据库UTF-8配置 + 小程序编码统一"
    },
    {
      "issue": "跨域问题",
      "solution": "FastAPI CORS中间件配置"
    },
    {
      "issue": "平台差异",
      "solution": "uni-app条件编译 + 平台API适配"
    }
  ],
  "project_structure": {
    "frontend": {
      "src/": [
        "pages/",
        "components/",
        "static/",
        "utils/",
        "store/"
      ],
      "manifest.json": "uni-app配置文件",
      "pages.json": "页面路由配置",
      "package.json": "项目依赖"
    },
    "backend": {
      "app/": [
        "models/",
        "routers/",
        "schemas/",
        "utils/"
      ],
      "requirements.txt": "FastAPI + SQLAlchemy 依赖",
      "main.py": "FastAPI 主入口"
    }
  },
  "commands": {
    "init": "创建uni-app项目并配置多端",
    "dev": "启动HBuilderX开发环境",
    "build": "构建各平台小程序",
    "deploy": "发布到小程序平台"
  },
  "roles": {
    "required": [
      "uniapp-engineer",
      "fastapi-engineer"
    ],
    "optional": [
      "project-manager",
      "ui-x-designer"
    ]
  },
  "milestones": [
    {
      "name": "项目启动",
      "deliverable": "uni-app项目结构和配置",
      "criteria": "多端项目初始化完成"
    },
    {
      "name": "核心功能",
      "deliverable": "可运行的小程序Demo",
      "criteria": "商品展示和购物车功能正常"
    },
    {
      "name": "后端集成",
      "deliverable": "完整的前后端应用",
      "criteria": "API接口调用正常"
    },
    {
      "name": "多端发布",
      "deliverable": "各平台小程序",
      "criteria": "微信、支付宝、百度小程序均发布成功"
    }
  ]
}